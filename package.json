{
  "name": "contract-call-debugger",
  "version": "1.0.0",
  "description": "Debugger for smart contract interactions and calls in TypeScript",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "test": "node --loader ts-node/esm tests/debugger.test.ts",
    "test:compiled": "node dist/tests/debugger.test.js",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "smart-contract",
    "debugger",
    "blockchain",
    "ethereum",
    "web3"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module"
}
